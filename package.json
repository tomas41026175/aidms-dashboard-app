{
  "name": "aidms-dashboard-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "concurrently -n server,vite -c cyan,magenta \"node server.js\" \"vite\"",
    "start:frontend": "vite",
    "start:backend": "node server.js",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aidms/chart-components": "file:../ChartComponents",
    "@emotion/react": "^11.13.5",
    "@emotion/styled": "^11.13.5",
    "@mui/material": "^7.0.0",
    "@mui/x-charts": "^7.28.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "systeminformation": "^5.23.14"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.9",
    "concurrently": "^9.2.1",
    "jsdom": "^27.0.1",
    "typescript": "^5.7.3",
    "vite": "^6.0.11",
    "vitest": "^2.1.9"
  }
}
